time_slots     (id PK, doctor_id FKв†’doctors, day_of_week INT(0-6),
                start_time TIME, end_time TIME, is_active BOOL)

-- Appointments вЂ” the core table
appointments   (id PK, patient_id FKв†’patients, doctor_id FKв†’doctors,
                slot_id FKв†’time_slots, date DATE, start_time TIME,
                status ENUM('scheduled','arrived','in_progress','done','cancelled','no_show'),
                notes_count INT DEFAULT 0, created_at, updated_at)

-- Indexes (query optimization):
-- INDEX ON appointments(doctor_id, date)     в†ђ doctor's daily queue
